                  "wallet_balance": { "type": "string", "example": "1500" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated successfully" },
          "400": { "description": "Lockout protection triggered or validation failed" },
          "404": { "description": "User or role not found" }
        }
      },
      "delete": {
        "summary": "Delete admin user",
