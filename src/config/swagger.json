      }
    },
    "/users/{id}": {
      "put": {
        "summary": "Update admin user details",
        "description": "Updates profile parameters (name, country, phone, lb_name, isIB, wallet_balance), roleId, or status. Prevents deactivating or demoting the bootstrap Super Admin.",
        "tags": ["Admin User Management"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Jane Doe" },
                  "email": { "type": "string", "format": "email", "example": "janedoe@example.com" },
                  "password": { "type": "string", "example": "NewPassword123!" },
                  "roleId": { "type": "string", "format": "uuid", "example": "new-role-uuid" },
                  "status": { "type": "string", "enum": ["active", "pending", "blocked"] },
                  "country": { "type": "string", "example": "Canada" },
                  "phone": { "type": "string", "example": "+15559876543" },
                  "lb_name": { "type": "string", "example": "Calgary Hub" },
